@prefix : <http://example.org/animals#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/animals> rdf:type owl:Ontology ;
    owl:versionIRI <http://example.org/animals/1.0> .

:hasHabitat rdf:type owl:ObjectProperty ;
    rdfs:label "has habitat"@en ;
    rdfs:domain :Animal ;
    rdfs:range :Habitat .

:hasParent rdf:type owl:ObjectProperty ;
    rdfs:label "has parent"@en ;
    rdfs:domain :Animal ;
    rdfs:range :Animal .

:hasPart rdf:type owl:TransitiveProperty ;
    rdfs:label "has part"@en .

:Animal rdf:type owl:Class ;
    rdfs:label "Animal"@en .

:Vertebrate rdf:type owl:Class ;
    rdfs:label "Vertebrate"@en ;
    rdfs:subClassOf :Animal .

:Mammal rdf:type owl:Class ;
    rdfs:label "Mammal"@en ;
    rdfs:subClassOf :Vertebrate .

:Bird rdf:type owl:Class ;
    rdfs:label "Bird"@en ;
    rdfs:subClassOf :Vertebrate ;
    owl:disjointWith :Mammal .

:Marsupial rdf:type owl:Class ;
    rdfs:label "Marsupial"@en ;
    rdfs:subClassOf :Mammal .

:Koala rdf:type owl:Class ;
    rdfs:label "Koala"@en ;
    rdfs:subClassOf :Marsupial .

:Habitat rdf:type owl:Class ;
    rdfs:label "Habitat"@en .

:Forest rdf:type owl:Class ;
    rdfs:label "Forest"@en ;
    rdfs:subClassOf :Habitat ;
    owl:disjointWith :Ocean .

:Ocean rdf:type owl:Class ;
    rdfs:label "Ocean"@en ;
    rdfs:subClassOf :Habitat .

:koko rdf:type owl:NamedIndividual , :Koala ;
    rdfs:label "Koko"@en .
